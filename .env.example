# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Found in: Stripe Dashboard → Connect → Settings (OAuth client ID)
STRIPE_CONNECT_CLIENT_ID=

# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Use http://localhost:3000 for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
